generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  goal                String?
  level               String?
  focusTime           String?
  masteryTier         String?  @default("Rookie 🌱")
  bestStreak          Int      @default(0)
  remindersEnabled    Boolean  @default(false)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  habits              Habit[]
  achievements        Achievement[]
}

model Habit {
  id          String     @id @default(cuid())
  title       String
  description String?
  icon        String?    @default("star-outline")
  color       String?    @default("#6366f1")
  frequency   String     @default("daily")
  targetValue Int?       @default(1)
  targetUnit  String?    @default("times")
  reminderTime String?   // HH:mm format
  timeOfDay    String?    @default("all") // morning, afternoon, evening
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  logs        HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  completed Boolean  @default(false)
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id])
}

model Achievement {
  id        String   @id @default(cuid())
  name      String   // Rookie, Master, etc.
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
